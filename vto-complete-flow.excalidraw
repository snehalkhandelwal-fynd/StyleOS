    {
      "id": "be-d555-label",
      "type": "text",
      "x": 1230,
      "y": 1225,
      "width": 330,
      "height": 200,
      "text": "D555 / MISURA HARDWARE\n\nHardware:\n  D555 depth camera (RGB + depth)\n  Mounted on mirror assembly\n\nLocal API Server:\n  Exposed via ngrok tunnel\n  URL stored in app_settings DB\n  measurement_api_url key\n\nEndpoints:\n  GET  /health        (check D555 conn)\n  POST /capture-front (front RGB+depth)\n  POST /capture-side  (side RGB+depth)\n  POST /get-dimensions (compute all)\n\nOutputs cm values for 10+ body points",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "strokeStyle": "solid",
      "seed": 86,
      "groupIds": [
        "be4"
      ],
      "boundElements": [],
      "locked": false,
      "roundness": null,
      "link": null,
      "updated": 1778490732387,
      "version": 2,
      "versionNonce": 1229078513,
      "index": "b0N",
      "isDeleted": false,
      "frameId": null,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "D555 / MISURA HARDWARE\n\nHardware:\n  D555 depth camera (RGB + depth)\n  Mounted on mirror assembly\n\nLocal API Server:\n  Exposed via ngrok tunnel\n  URL stored in app_settings DB\n  measurement_api_url key\n\nEndpoints:\n  GET  /health        (check D555 conn)\n  POST /capture-front (front RGB+depth)\n  POST /capture-side  (side RGB+depth)\n  POST /get-dimensions (compute all)\n\nOutputs cm values for 10+ body points",
      "autoResize": true,
      "lineHeight": 1.0101010101010102
    },
