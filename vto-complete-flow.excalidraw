    {
      "id": "screen-80-desc",
      "type": "text",
      "x": 400,
      "y": 190,
      "width": 320,
      "height": 150,
      "text": "Route: /c/vto-display\nLarge portrait TV mounted as mirror\n\nStates:\n• idle → Splash/editorial screens\n• capture → Camera captures full body\n• capture_done → Shows captured photo\n• browsing → Photo + measurements overlay\n• loading → \"Creating Your Look\" animation\n• revealing → Merge animation\n• ready → Shows generated VTO look",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "strokeStyle": "solid",
      "seed": 18,
      "groupIds": [
        "screens"
      ],
      "boundElements": [],
      "locked": false,
      "roundness": null,
      "link": null,
      "updated": 1778490732387,
      "version": 2,
      "versionNonce": 1100078129,
      "index": "aH",
      "isDeleted": false,
      "frameId": null,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Route: /c/vto-display\nLarge portrait TV mounted as mirror\n\nStates:\n• idle → Splash/editorial screens\n• capture → Camera captures full body\n• capture_done → Shows captured photo\n• browsing → Photo + measurements overlay\n• loading → \"Creating Your Look\" animation\n• revealing → Merge animation\n• ready → Shows generated VTO look",
      "autoResize": true,
      "lineHeight": 1.1363636363636365
    },
